APP_NAME="Stripe Toolkit Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Single-machine (default):
APP_URL=http://localhost:8000

# To test from another device on the LAN (phone, tablet, second laptop),
# replace APP_URL with your machine's LAN IP and start the server bound
# to all interfaces (see DEMO.md "Terminal 1"):
#   APP_URL=http://192.168.1.152:8000
#   php artisan serve --host=0.0.0.0 --port=8000 --no-reload
# Find your LAN IP with: hostname -I | awk '{print $1}'

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Required so the kit's debug inspector can POST to itself for the
# embedded form trigger. Pair with `php artisan serve --no-reload`.
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# `database` queues async webhook processing — the demo runs
# `php artisan queue:work --queue=stripe-webhooks` in a second terminal.
# Switch to `sync` to run handlers inline (no worker required, easier
# to debug, but loses the realistic queue semantics).
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ────────────────────────────────────────────────────────────────────
# Stripe Toolkit · Webhooks
# ────────────────────────────────────────────────────────────────────
#
# All three keys below are REQUIRED for the demo. Use TEST MODE keys —
# this app is not configured for live payments.
#
# Get the publishable + secret keys from:
#   https://dashboard.stripe.com/test/apikeys
#
# Get the webhook signing secret in one of two ways:
#
#   (A) Stripe CLI — recommended for local development.
#       1. Install:    https://stripe.com/docs/stripe-cli
#       2. Authenticate once:
#            stripe login
#       3. Forward events to your local app:
#            stripe listen --forward-to http://localhost:8000/stripe/webhook
#       4. Copy the `whsec_…` it prints into STRIPE_WEBHOOK_SECRET below.
#          The secret is stable per Stripe account, so you only do this
#          once unless you regenerate it.
#
#   (B) Public tunnel + Dashboard endpoint — for testing from
#       phones / external services.
#       1. Expose port 8000 publicly:
#            tailscale funnel 8000
#            # or: cloudflared tunnel --url http://localhost:8000
#            # or: ngrok http 8000
#       2. Stripe Dashboard → Developers → Webhooks → Add endpoint
#          URL:    https://<your-tunnel-host>/stripe/webhook
#          Events: checkout.session.completed,
#                  checkout.session.async_payment_succeeded,
#                  payment_intent.succeeded,
#                  payment_intent.payment_failed,
#                  charge.refunded
#       3. Copy that endpoint's "Signing secret" into
#          STRIPE_WEBHOOK_SECRET below.

STRIPE_KEY=pk_test_replace_me
STRIPE_SECRET=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ────────────────────────────────────────────────────────────────────
# Kit knobs (optional — sensible defaults already shipped)
# ────────────────────────────────────────────────────────────────────

# Force the debug inspector on/off. Default: enabled in non-production.
# STRIPE_WEBHOOKS_DEBUG=true

# Override the inspector mount point (default: stripe-webhooks-debug).
# STRIPE_WEBHOOKS_DEBUG_PATH=internal/webhooks

# Override the queue connection used to dispatch ProcessStripeWebhook.
# Defaults to QUEUE_CONNECTION.
# STRIPE_QUEUE_CONNECTION=redis

# Override the queue name (default: stripe-webhooks).
# STRIPE_QUEUE_NAME=high-priority

# License key for the upcoming Pro module (no effect on the free core).
# STRIPE_WEBHOOKS_PRO_LICENSE=

# ────────────────────────────────────────────────────────────────────
# Demo product (the storefront's single SKU)
# ────────────────────────────────────────────────────────────────────
DEMO_PRODUCT_NAME="Bulletproof Coffee"
DEMO_PRODUCT_PRICE=420
DEMO_PRODUCT_CURRENCY=eur
